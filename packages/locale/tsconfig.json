{
  "extends": "@fuyeor/tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vite/client",
      "node"
    ],
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
}